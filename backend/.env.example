# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./paper_trading.db

# ── Binance (public endpoints, no key needed) ──
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_REST_URL=https://api.binance.com

# ── Trading Defaults ──
DEFAULT_BALANCE_USDT=1000
TRADING_INTERVAL_SECONDS=300
TRADING_SYMBOL=BTCUSDT

# ── Claude AI (Phase 3 — add your key when ready) ──
ANTHROPIC_API_KEY=your-key-here
MAX_CONCURRENT_AI_CALLS=3
AI_COOLDOWN_SECONDS=60

# ── Server ──
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── Fee Model ──
SPOT_FEE_RATE=0.001
BNB_DISCOUNT_FEE_RATE=0.00075
