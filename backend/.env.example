# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./paper_trading.db

# ── Binance (public endpoints, no key needed) ──
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_REST_URL=https://api.binance.com

# ── Trading Defaults ──
DEFAULT_BALANCE_USDT=1000
TRADING_INTERVAL_SECONDS=300
TRADING_SYMBOL=BTCUSDT

# ── AI Source Of Truth ──
AI_PROVIDER=anthropic
AI_MODEL=claude-3-5-sonnet-20240620

# Optional generic overrides for the active provider above.
# If unset, the app falls back to the provider-specific values below.
# AI_API_KEY=
# AI_BASE_URL=

# ── Provider Keys / Defaults ──
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
OPENAI_API_KEY=your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

AI_CONCURRENT_CALLS=3
AI_MIN_COOLDOWN_SECONDS=60

# ── Server ──
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ── WhatsApp Notifications (Twilio) ──
# Get credentials from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
# Comma-separated list of WhatsApp numbers to notify (e.g. +1234567890,+0987654321)
TWILIO_WHATSAPP_TO=

# ── Fee Model ──
SPOT_FEE_RATE=0.001
BNB_DISCOUNT_FEE_RATE=0.00075
